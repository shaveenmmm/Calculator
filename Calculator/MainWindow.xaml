<Window
    x:Class="CalculatorApp.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Calculator"
    Width="300"
    Height="420"
    Background="#1E1E2F">

    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="80" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBox
            x:Name="Display"
            Grid.Row="0"
            HorizontalContentAlignment="Right"
            VerticalContentAlignment="Center"
            Background="#2D2D44"
            BorderThickness="0"
            FontSize="26"
            Foreground="White"
            IsReadOnly="True"
            Text="0" />

        <UniformGrid
            Grid.Row="1"
            Columns="4"
            Rows="4">

            <Button Click="Number_Click" Content="7" />
            <Button Click="Number_Click" Content="8" />
            <Button Click="Number_Click" Content="9" />
            <Button Click="Operator_Click" Content="/" />

            <Button Click="Number_Click" Content="4" />
            <Button Click="Number_Click" Content="5" />
            <Button Click="Number_Click" Content="6" />
            <Button Click="Operator_Click" Content="*" />

            <Button Click="Number_Click" Content="1" />
            <Button Click="Number_Click" Content="2" />
            <Button Click="Number_Click" Content="3" />
            <Button Click="Operator_Click" Content="-" />

            <Button Click="Clear_Click" Content="C" />
            <Button Click="Number_Click" Content="0" />
            <Button Click="Equals_Click" Content="=" />
            <Button Click="Operator_Click" Content="+" />

        </UniformGrid>

    </Grid>
</Window>
